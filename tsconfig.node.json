{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "bun"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "vite.web.config.ts",
    "vite.tauri.config.ts",
    "src/shared/**/*.ts",
    "backend/**/*.ts",
    "tools/**/*.ts",
    "drizzle.config.ts"
  ]
}
