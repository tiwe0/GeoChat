{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeoChat",
  "version": "0.2.8",
  "identifier": "ai.geochat.desktop",
  "build": {
    "beforeDevCommand": "bun run tauri:renderer:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run tauri:prepare",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "GeoChat",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/backend",
      "../dist/runtime",
      "../dist/renderer",
      "../dist/vendor",
      "../dist/app-bundle-manifest.json"
    ]
  }
}
